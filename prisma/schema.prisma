// ═══════════════════════════════════════════════════════════════════════════
// PRISMA SCHEMA — Motor Universal de Endosos
// Base de datos: PostgreSQL 16
// Estrategia Multitenancy: Row-Level Security con columna tenant_id
//
// Convención de nomenclatura:
//   - Tablas:  snake_case plural  (endorsements, tenant_configs)
//   - Modelos: PascalCase singular (Endorsement, TenantConfig)
//   - Campos:  camelCase          (tenantId, policyId)
// ═══════════════════════════════════════════════════════════════════════════

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── TENANTS (Aseguradoras) ──────────────────────────────────────────────────
// Cada aseguradora es un "tenant" del sistema.
// Su configuración completa vive en TenantConfig como JSONB.

model Tenant {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  slug      String   @unique @db.VarChar(100)  // Ej: "la-mundial", "synergy-health"
  name      String   @db.VarChar(255)
  shortName String   @map("short_name") @db.VarChar(100)
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Relaciones
  config       TenantConfig?
  endorsements Endorsement[]

  @@map("tenants")
}

// ─── TENANT CONFIG (Configuración por Aseguradora) ──────────────────────────
// Almacena la configuración completa en JSONB.
// Esto permite flexibilidad máxima sin sacrificar estructura relacional.
//
// El campo `schema` es tipo Json y contiene el objeto InsurerConfig completo
// del frontend, incluyendo: endorsementTypes, workflows, channels, branches,
// tariff tables, rules, etc.

model TenantConfig {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId   String   @unique @map("tenant_id") @db.Uuid
  /// Configuración completa de la aseguradora como JSONB.
  /// Estructura: InsurerConfig (ver src/types/config.types.ts del frontend)
  schema     Json     @db.JsonB
  version    Int      @default(1)
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  // Relación
  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@map("tenant_configs")
}

// ─── ENDORSEMENTS (Endosos) ──────────────────────────────────────────────────
// Tabla transaccional principal. Cada fila es una solicitud/endoso.
// El campo `calculation` guarda el detalle financiero como JSONB para
// preservar el snapshot exacto del cálculo en el momento de emisión.
// El campo `formData` guarda los campos dinámicos del formulario.

model Endorsement {
  id                 String            @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  /// Aislamiento multitenancy — SIEMPRE filtrar por este campo
  tenantId           String            @map("tenant_id") @db.Uuid
  policyId           String            @map("policy_id") @db.VarChar(100)
  endorsementTypeId  String            @map("endorsement_type_id") @db.VarChar(100)
  routeId            String?           @map("route_id") @db.VarChar(100)
  channelId          String            @map("channel_id") @db.VarChar(100)
  effectiveDate      DateTime          @map("effective_date") @db.Date
  status             EndorsementStatus @default(DRAFT)
  workflowStep       String?           @map("workflow_step") @db.VarChar(100)
  /// Snapshot del cálculo financiero (prorrateo, impuestos, total).
  /// Guardado como JSONB para preservar el estado exacto en la emisión.
  calculation        Json?             @db.JsonB
  /// Datos del formulario dinámico. Estructura variable según aseguradora.
  formData           Json?             @map("form_data") @db.JsonB
  /// Lista de IDs de reglas que se evaluaron al momento de la solicitud.
  appliedRules       String[]          @map("applied_rules")
  /// Número de endoso secuencial por aseguradora (generado por trigger)
  endorsementNumber  String?           @map("endorsement_number") @db.VarChar(50)
  rejectionReason    String?           @map("rejection_reason") @db.Text
  createdAt          DateTime          @default(now()) @map("created_at")
  updatedAt          DateTime          @updatedAt @map("updated_at")
  emittedAt          DateTime?         @map("emitted_at")

  // Relaciones
  tenant    Tenant              @relation(fields: [tenantId], references: [id])
  auditLogs EndorsementAudit[]

  @@index([tenantId, policyId])
  @@index([tenantId, status])
  @@index([tenantId, createdAt])
  @@map("endorsements")
}

// ─── ENDORSEMENT AUDIT LOG ───────────────────────────────────────────────────
// Registro inmutable de eventos. Se appends-only, nunca se modifica.
// Cada cambio de estado, validación, cálculo queda registrado aquí.

model EndorsementAudit {
  id            String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  endorsementId String   @map("endorsement_id") @db.Uuid
  tenantId      String   @map("tenant_id") @db.Uuid
  event         String   @db.VarChar(100)  // Ej: "STATUS_CHANGED", "RULE_EVALUATED"
  user          String   @db.VarChar(255)  // Ej: "system", "user@email.com"
  /// Datos adicionales del evento (diff de campos, resultado de reglas, etc.)
  data          Json     @db.JsonB
  createdAt     DateTime @default(now()) @map("created_at")

  // Relación
  endorsement Endorsement @relation(fields: [endorsementId], references: [id], onDelete: Cascade)

  @@index([endorsementId])
  @@index([tenantId, event])
  @@map("endorsement_audit_logs")
}

// ─── ENUMERACIONES ────────────────────────────────────────────────────────────
enum EndorsementStatus {
  DRAFT             // Borrador inicial
  PENDING_PAYMENT   // Pendiente de pago
  PENDING_APPROVAL  // En flujo de aprobación
  EMITTED           // Emitido exitosamente
  REJECTED          // Rechazado

  @@map("endorsement_status")
}

// ─── CACHE DE POLIZAS ──────────────────────────────────────────────────────────
// Almacena temporalmente los datos de las pólizas consultadas al Core externo.
model PolicyCache {
  policyId  String   @id @map("policy_id") @db.VarChar(100)
  data      Json     @db.JsonB
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("policy_cache")
}
