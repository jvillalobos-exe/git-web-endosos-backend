{
  "openapi": "3.0.0",
  "paths": {
    "/endosos-services/endorsements": {
      "post": {
        "description": "\nFlujo completo de emisión de endoso:\n1. Consulta la póliza al Core (adaptador configurado)\n2. Evalúa las reglas de elegibilidad del tenant\n3. Calcula el costo según la ruta configurada\n4. Persiste en transacción atómica (con auditoría)\n5. Retorna el endoso con su estado final\n\n**Estados posibles de respuesta:**\n- `EMITTED`: Endoso emitido directamente (sin pago ni aprobación)\n- `PENDING_PAYMENT`: Endoso requiere pago previo\n- `PENDING_APPROVAL`: Endoso enviado a flujo de aprobación manual\n    ",
        "operationId": "EndorsementsController_create",
        "parameters": [
          {
            "name": "X-Tenant-Id",
            "in": "header",
            "description": "UUID del tenant (aseguradora). Ej: a1b2c3d4-...",
            "required": true,
            "schema": {
              "type": "string",
              "format": "uuid"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/CreateEndorsementDto"
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Endoso creado exitosamente",
            "content": {
              "application/json": {
                "schema": {
                  "example": {
                    "id": "uuid-del-endoso",
                    "policyId": "POL-001",
                    "status": "EMITTED",
                    "endorsementNumber": "END-2025-000001",
                    "calculation": {
                      "proratedAmount": 87.5,
                      "totalCharge": 91,
                      "formula": "(650 - 450) / 365 × 160 días = 87.67"
                    },
                    "emittedAt": "2025-01-15T14:30:00Z"
                  }
                }
              }
            }
          },
          "400": {
            "description": "Datos inválidos o reglas bloqueantes"
          },
          "404": {
            "description": "Póliza o tenant no encontrado"
          }
        },
        "summary": "Crear y emitir un endoso",
        "tags": [
          "Endorsements",
          "Endosos"
        ]
      },
      "get": {
        "description": "Retorna los endosos del tenant activo con filtros y paginación.",
        "operationId": "EndorsementsController_findAll",
        "parameters": [
          {
            "name": "X-Tenant-Id",
            "in": "header",
            "description": "UUID del tenant (aseguradora). Ej: a1b2c3d4-...",
            "required": true,
            "schema": {
              "type": "string",
              "format": "uuid"
            }
          },
          {
            "name": "policyId",
            "required": false,
            "in": "query",
            "description": "Filtrar por póliza",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "status",
            "required": false,
            "in": "query",
            "schema": {
              "enum": [
                "DRAFT",
                "PENDING_PAYMENT",
                "PENDING_APPROVAL",
                "EMITTED",
                "REJECTED"
              ],
              "type": "string"
            }
          },
          {
            "name": "endorsementTypeId",
            "required": false,
            "in": "query",
            "description": "Filtrar por tipo de endoso",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "search",
            "required": false,
            "in": "query",
            "description": "Filtrar por texto de búsqueda",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "page",
            "required": false,
            "in": "query",
            "schema": {
              "example": 1,
              "type": "number"
            }
          },
          {
            "name": "limit",
            "required": false,
            "in": "query",
            "schema": {
              "example": 20,
              "type": "number"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Lista paginada de endosos"
          }
        },
        "summary": "Listar endosos del tenant",
        "tags": [
          "Endorsements",
          "Endosos"
        ]
      }
    },
    "/endosos-services/endorsements/dashboard/stats": {
