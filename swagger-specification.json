            }
          },
          {
            "name": "policyId",
            "required": true,
            "in": "path",
            "schema": {
              "example": "POL-001",
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Snapshot de la póliza",
            "content": {
              "application/json": {
                "schema": {
                  "example": {
                    "policyId": "POL-001",
                    "insuredName": "María García Rodríguez",
                    "planCode": "BASIC",
                    "planLabel": "Plan Básico",
                    "annualPremium": 450,
                    "daysRemaining": 180,
                    "status": "active",
                    "debtDays": 0,
                    "openClaims": 0
