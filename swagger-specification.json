  "info": {
    "title": "Motor Universal de Endosos — API",
    "description": "## API REST para el Motor Universal de Endosos\n\n### Autenticación Multitenancy\nTodos los endpoints requieren el header **X-Tenant-Id** con el UUID de la aseguradora.\n\n### Arquitectura\nEste motor implementa arquitectura hexagonal (Ports & Adapters):\n- **IPolicyPort**: Adaptador para consultar pólizas del Core del asegurador\n- **ICatalogPort**: Adaptador para catálogos de coberturas\n- La configuración específica por aseguradora vive en JSONB (`tenant_configs.schema`)\n\n### Endpoints disponibles\n- `POST /api/endorsements` — Crear y emitir endoso (transaccional)\n- `GET /api/endorsements` — Listar endosos con filtros\n- `POST /api/endorsements/evaluate` — Pre-evaluar reglas\n- `POST /api/endorsements/calculate` — Pre-calcular costo\n- `GET /api/policies/:id` — Consultar póliza al Core\n- `GET /api/tenants/:id/config` — Obtener configuración del tenant\n- `PUT /api/tenants/:id/config` — Actualizar configuración del tenant",
    "version": "1.0",
    "contact": {}
  },
  "tags": [
    {
      "name": "Endosos",
      "description": "Operaciones de emisión y consulta de endosos"
    },
    {
      "name": "Pagos",
      "description": "Operaciones de pago y callback de pasarela"
    },
    {
      "name": "Pólizas",
      "description": "Consulta de pólizas al Core del asegurador"
    },
    {
      "name": "Configuración de Tenants",
      "description": "Gestión de la configuración por aseguradora"
    }
  ],
  "servers": [],
  "components": {
    "securitySchemes": {
      "X-Tenant-Id": {
        "type": "apiKey",
        "in": "header",
        "name": "X-Tenant-Id",
        "description": "UUID del tenant (aseguradora)"
      }
    },
    "schemas": {
      "CreateEndorsementDto": {
        "type": "object",
        "properties": {
          "policyId": {
            "type": "string",
            "description": "ID de la póliza en el sistema del asegurador",
            "example": "POL-001",
            "minLength": 1,
            "maxLength": 100
          },
          "endorsementTypeId": {
            "type": "string",
            "description": "ID del tipo de endoso según la configuración del tenant",
            "example": "plan-increment",
            "minLength": 1,
            "maxLength": 100
          },
          "routeId": {
            "type": "string",
            "description": "ID de la ruta de endoso (para endosos cuantitativos)",
            "example": "route-basic-to-plata"
          },
          "channelId": {
            "type": "string",
            "description": "ID del canal de venta (backoffice, digital, agencia, etc.)",
            "example": "backoffice",
            "minLength": 1,
            "maxLength": 100
          },
          "effectiveDate": {
            "type": "string",
            "description": "Fecha efectiva del endoso (ISO 8601: YYYY-MM-DD)",
            "example": "2025-01-15",
            "format": "date"
          },
          "formData": {
            "type": "object",
            "description": "Datos del formulario dinámico. Campos según el tipo de endoso.",
            "example": {
              "newPlanCode": "PLATA",
              "reason": "Mejora de cobertura"
            }
          }
        },
        "required": [
          "policyId",
          "endorsementTypeId",
          "channelId",
          "effectiveDate"
        ]
      },
      "EvaluateRulesDto": {
        "type": "object",
        "properties": {
          "policyId": {
            "type": "string",
            "description": "ID de la póliza",
            "example": "POL-001"
          },
          "channelId": {
            "type": "string",
            "description": "ID del canal",
            "example": "backoffice"
          }
        },
        "required": [
          "policyId",
          "channelId"
        ]
      },
      "CalculateEndorsementDto": {
        "type": "object",
        "properties": {
          "policyId": {
            "type": "string",
            "description": "ID de la póliza",
            "example": "POL-001"
          },
          "routeId": {
            "type": "string",
            "description": "ID de la ruta de endoso",
            "example": "route-basic-to-plata"
          },
          "effectiveDate": {
            "type": "string",
            "description": "Fecha efectiva del endoso",
            "example": "2025-01-15"
          }
        },
        "required": [
          "policyId",
          "routeId",
          "effectiveDate"
        ]
      },
      "PaymentSessionDto": {
        "type": "object",
        "properties": {
          "policyId": {
            "type": "string",
            "description": "ID de la póliza",
            "example": "POL-001"
          },
          "amount": {
            "type": "number",
            "description": "Monto a cobrar",
            "example": 100
          },
          "currency": {
            "type": "string",
            "description": "Moneda (USD o VES)",
            "example": "USD"
          },
          "concept": {
            "type": "string",
            "description": "Concepto de cobro",
            "example": "Diferencia de prima"
          }
        },
        "required": [
          "policyId",
          "amount",
          "currency"
        ]
      },
      "UpdateTenantConfigDto": {
        "type": "object",
        "properties": {
          "schema": {
            "type": "object",
            "description": "Configuración completa de la aseguradora (InsurerConfig)",
            "additionalProperties": true
          }
        },
        "required": [
          "schema"
        ]
      }
    }
  }
}