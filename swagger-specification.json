            "schema": {
              "type": "string"
            }
          },
          {
            "name": "status",
            "required": true,
            "in": "query",
            "description": "success o failed",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "reference",
            "required": false,
            "in": "query",
            "description": "Referencia del pago",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "message",
            "required": false,
            "in": "query",
            "description": "Mensaje",
            "schema": {
