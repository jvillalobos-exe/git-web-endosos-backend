        "tags": [
          "Endorsements",
          "Pagos"
        ]
      },
      "post": {
        "description": "Recibe el estado final del pago y lo almacena temporalmente para que el cliente lo consulte.",
        "operationId": "EndorsementsController_handlePaymentCallbackPost",
        "parameters": [
          {
            "name": "X-Tenant-Id",
            "in": "header",
            "description": "UUID del tenant (aseguradora). Ej: a1b2c3d4-...",
            "required": true,
            "schema": {
              "type": "string",
              "format": "uuid"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "policyId": {
                    "type": "string",
                    "description": "ID de la póliza asociada al pago"
                  },
                  "status": {
                    "type": "string",
                    "enum": [
                      "success",
                      "failed"
                    ],
                    "description": "Estado del pago"
                  },
                  "reference": {
                    "type": "string",
                    "description": "Referencia de la transacción"
                  },
                  "message": {
                    "type": "string",
                    "description": "Mensaje adicional"
                  }
                },
                "required": [
                  "policyId",
                  "status"
                ]
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": ""
          }
        },
        "summary": "Recibir confirmación del pago desde la pasarela (Webhook)",
        "tags": [
          "Endorsements",
          "Pagos"
        ]
      }
    },
